set-environment -g TMUX_PLUGIN_MANAGER_PATH "~/.tmux/plugins/"

# Ensure tmux/brew binaries are on PATH inside `run-shell` (plugin scripts
# like tpm and catppuccin invoke `tmux` directly and get 127 otherwise)
{{ if eq .chezmoi.os "darwin" -}}
set-environment -g PATH "/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"
{{ else -}}
set-environment -g PATH "/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
set-environment -g WAYLAND_DISPLAY "$WAYLAND_DISPLAY"
{{ end -}}

set-option -g allow-passthrough on
set-option -g set-clipboard on

# window title
set-option -g set-titles on
set-option -g set-titles-string '#T'

# word navigation (M-Left/Right)
bind -n M-Left  send-keys "\eb"
bind -n M-Right send-keys "\ef"

# clear screen (C-l passthrough — tmux-sensible sobrescreve o default)
bind -n C-l send-keys C-l

set -g default-terminal "tmux-256color"
{{ if eq .chezmoi.os "darwin" -}}
set -as terminal-overrides ",alacritty:RGB"
{{ else -}}
set -as terminal-overrides ",alacritty:RGB"
{{ end -}}

# unicode underline
set -as terminal-overrides ',*:Smulx=\E[4::%p1%dm'
set -as terminal-overrides ',*:Setulc=\E[58::2::%p1%{65536}%/%d::%p1%{256}%/%{255}%&%d::%p1%{255}%&%d%;m'

# open new panes/windows in current dir
bind c new-window      -c "#{pane_current_path}"
bind '"' split-window  -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"

set -g mouse on

# Mouse: movimento simples não deve iniciar seleção do terminal.
# Só focar no clique; seleção/copy só em clique+arrasto intencional dentro do tmux.
# Em Ghostty, MouseUp1Pane é mais confiável para foco do que MouseDown1Pane.
bind -n MouseUp1Pane select-pane -t=
bind -n MouseDrag1Pane select-pane -t= \; copy-mode -M
bind -n MouseDrag1Border resize-pane -M

set -g base-index 1
set -g history-limit 20000
set -sg repeat-time 600
set -sg escape-time 0
set -g focus-events on

setw -g mode-keys vi

bind -T copy-mode-vi v send -X begin-selection
{{ if eq .chezmoi.os "darwin" -}}
bind -T copy-mode-vi y              send-keys -X copy-pipe-and-cancel "pbcopy"
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"
{{ else -}}
bind -T copy-mode-vi y              send-keys -X copy-pipe-and-cancel "if [ -n \"$WAYLAND_DISPLAY\" ]; then wl-copy; else cat > /dev/null; fi"
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "if [ -n \"$WAYLAND_DISPLAY\" ]; then wl-copy; else cat > /dev/null; fi"
{{ end -}}
# Não cancele copy-mode/scrollback ao clicar dentro do pane: isso pulava de volta
# para o fim da tela. Deixe o binding padrão do tmux cuidar do clique.
unbind -T copy-mode-vi MouseDown1Pane
bind -T copy-mode-vi MouseDrag1Pane select-pane


bind r source-file ~/.tmux.conf \; display-message "~/.tmux.conf reloaded."

set-option -a terminal-features 'xterm-256color:RGB'

# activity (visual off = evita spam de mensagens em muitos panes)
setw -g monitor-activity on
set  -g visual-activity off

# re-number windows when one is closed
set -g renumber-windows on

# neovim cursor shape integration
set -g -a terminal-overrides ',*:Ss=\E[%p1%d q:Se=\E[2 q'

set-window-option -g pane-base-index 1
set-option -g allow-rename off

# ── Plugins ───────────────────────────────────────────────────────────────────
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'catppuccin/tmux'
set -g @plugin 'tmux-plugins/tmux-cpu'
set -g @plugin 'xamut/tmux-weather'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'tmux-plugins/tmux-logging'
set -g @plugin 'tmux-plugins/tmux-cowboy'
set -g @plugin 'tmux-plugins/tmux-open'
set -g @plugin 'tmux-plugins/tmux-urlview'
set -g @plugin 'laktak/extrakto'
set -g @plugin 'tmux-plugins/tmux-resurrect'

set -g @resurrect-strategy-vim  'session'
set -g @resurrect-strategy-nvim 'session'

# ── Catppuccin (v2) ───────────────────────────────────────────────────────────
set -g @catppuccin_flavor "mocha"

# Window styling
set -g @catppuccin_window_status_style "rounded"
set -g @catppuccin_window_number_position "left"
# Catppuccin v2: inactive windows collapsed to number only; current keeps title.
set -g @catppuccin_window_text ""
set -g @catppuccin_window_number "#I"
set -g @catppuccin_window_current_text " #W"
set -g @catppuccin_window_current_number "#I"

# Status separators
set -g @catppuccin_status_left_separator  ""
set -g @catppuccin_status_right_separator ""
set -g @catppuccin_status_middle_separator ""
set -g @catppuccin_status_fill "all"
set -g @catppuccin_status_connect_separator "no"
set -g @catppuccin_status_background "default"

# Date/time (p10k style)
set -g @catppuccin_date_time_icon " "
set -g @catppuccin_date_time_color "#{@thm_pink}"
set -g @catppuccin_date_time_text " at %H:%M:%S"

# Weather (pt-BR, Santos)
set-environment -g TMUX_WEATHER_LOCATION "Santos,BR"
set -g @catppuccin_cpu_text     " #(~/.tmux/plugins/tmux-cpu/scripts/cpu_percentage.sh | sed 's/[.]0%$/%/')"
set -g @catppuccin_weather_text " #(~/.tmux/scripts/weather-cached.sh)"

# Load Catppuccin before assembling status-left/right
# (source confs directly: `run` on catppuccin.tmux fails because tmux resets
#  PATH inside run-shell and can't find /usr/local/bin/tmux → exit 127)
source-file -q ~/.tmux/plugins/tmux/catppuccin_options_tmux.conf
source-file -q ~/.tmux/plugins/tmux/catppuccin_tmux.conf

# ── Status bar ────────────────────────────────────────────────────────────────
set -g status-position bottom
set -g status on
set -g status-right-length 300
set -g status-left-length  150
set -g status-interval 15

set -g status-left  "#{E:@catppuccin_status_session}"
set -g status-right "#{E:@catppuccin_status_cpu}#{E:@catppuccin_status_uptime}#{E:@catppuccin_status_date_time}#{E:@catppuccin_status_weather}"

# One line by default. status-lines.sh switches to 2 lines only when width is tight.
set -g @tmux_status_format_oneline "#[align=left range=left #{E:status-left-style}]#[push-default]#{T;=/#{status-left-length}:status-left}#[pop-default]#[norange default]#[list=on align=#{status-justify}]#[list=left-marker]<#[list=right-marker]>#[list=on]#{W:#[range=window|#{window_index} #{E:window-status-style}#{?#{&&:#{window_last_flag},#{!=:#{E:window-status-last-style},default}}, #{E:window-status-last-style},}#{?#{&&:#{window_bell_flag},#{!=:#{E:window-status-bell-style},default}}, #{E:window-status-bell-style},#{?#{&&:#{||:#{window_activity_flag},#{window_silence_flag}},#{!=:#{E:window-status-activity-style},default}}, #{E:window-status-activity-style},}}]#[push-default]#{T:window-status-format}#[pop-default]#[norange default]#{?loop_last_flag,,#{window-status-separator}},#[range=window|#{window_index} list=focus #{?#{!=:#{E:window-status-current-style},default},#{E:window-status-current-style},#{E:window-status-style}}#{?#{&&:#{window_last_flag},#{!=:#{E:window-status-last-style},default}}, #{E:window-status-last-style},}#{?#{&&:#{window_bell_flag},#{!=:#{E:window-status-bell-style},default}}, #{E:window-status-bell-style},#{?#{&&:#{||:#{window_activity_flag},#{window_silence_flag}},#{!=:#{E:window-status-activity-style},default}}, #{E:window-status-activity-style},}}]#[push-default]#{T:window-status-current-format}#[pop-default]#[norange list=on default]#{?loop_last_flag,,#{window-status-separator}}}#[nolist align=right range=right #{E:status-right-style}]#[push-default]#{T;=/#{status-right-length}:status-right}#[pop-default]#[norange default]"
set -g @tmux_status_format_windows "#[align=left range=left #{E:status-left-style}]#[push-default]#{T;=/#{status-left-length}:status-left}#[pop-default]#[norange default]#[list=on align=#{status-justify}]#[list=left-marker]<#[list=right-marker]>#[list=on]#{W:#[range=window|#{window_index} #{E:window-status-style}#{?#{&&:#{window_last_flag},#{!=:#{E:window-status-last-style},default}}, #{E:window-status-last-style},}#{?#{&&:#{window_bell_flag},#{!=:#{E:window-status-bell-style},default}}, #{E:window-status-bell-style},#{?#{&&:#{||:#{window_activity_flag},#{window_silence_flag}},#{!=:#{E:window-status-activity-style},default}}, #{E:window-status-activity-style},}}]#[push-default]#{T:window-status-format}#[pop-default]#[norange default]#{?loop_last_flag,,#{window-status-separator}},#[range=window|#{window_index} list=focus #{?#{!=:#{E:window-status-current-style},default},#{E:window-status-current-style},#{E:window-status-style}}#{?#{&&:#{window_last_flag},#{!=:#{E:window-status-last-style},default}}, #{E:window-status-last-style},}#{?#{&&:#{window_bell_flag},#{!=:#{E:window-status-bell-style},default}}, #{E:window-status-bell-style},#{?#{&&:#{||:#{window_activity_flag},#{window_silence_flag}},#{!=:#{E:window-status-activity-style},default}}, #{E:window-status-activity-style},}}]#[push-default]#{T:window-status-current-format}#[pop-default]#[norange list=on default]#{?loop_last_flag,,#{window-status-separator}}}"
set -g status-format[0] "#{E:@tmux_status_format_oneline}"
set -g status-format[1] "#[align=right range=right #{E:status-right-style}]#[push-default]#{T;=/#{status-right-length}:status-right}#[pop-default]#[norange default]"
set-hook -g client-resized 'run-shell -b ~/.tmux/scripts/status-lines.sh'
set-hook -g window-linked 'run-shell -b ~/.tmux/scripts/status-lines.sh'
set-hook -g window-unlinked 'run-shell -b ~/.tmux/scripts/status-lines.sh'
set-hook -g window-renamed 'run-shell -b ~/.tmux/scripts/status-lines.sh'
run-shell -b ~/.tmux/scripts/status-lines.sh

# Initialize TPM (keep at bottom)
run '~/.tmux/plugins/tpm/tpm'
set -g @continuum-save-interval '15'
set -g @resurrect-processes 'false'
set -g @resurrect-capture-pane-contents 'off'
