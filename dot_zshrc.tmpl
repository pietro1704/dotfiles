# ── Powerlevel10k instant prompt (deve ficar no topo) ────────────────────────
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ── PATH (typeset -U remove duplicatas automaticamente) ──────────────────────
typeset -U path
{{ if eq .chezmoi.os "darwin" -}}
# Hardcoded — evita subshell `brew --prefix` (~50ms). Ajustar se mudar de máquina.
if [ -x "/opt/homebrew/bin/brew" ]; then
  HOMEBREW_PREFIX="/opt/homebrew"
elif [ -x "/usr/local/bin/brew" ]; then
  HOMEBREW_PREFIX="/usr/local"
else
  HOMEBREW_PREFIX=""
fi

# JDK 17 (Pinterest iOS / Android toolchain)
[ -d "/usr/local/jdk-17.0.6.jdk/Contents/Home" ] && export JAVA_HOME="/usr/local/jdk-17.0.6.jdk/Contents/Home"

export PYENV_ROOT="$HOME/.pyenv"

path=(
  $HOME/.local/bin
  $HOME/bin
  ${HOMEBREW_PREFIX:+$HOMEBREW_PREFIX/bin}
  ${HOMEBREW_PREFIX:+$HOMEBREW_PREFIX/sbin}
  ${HOMEBREW_PREFIX:+$HOMEBREW_PREFIX/opt/curl/bin}
  $PYENV_ROOT/bin
  ${JAVA_HOME:+$JAVA_HOME/bin}
  $HOME/.ghcup/bin
  $HOME/.xcodes/1.4.1/bin
  $HOME/.emacs.d/bin
  $HOME/.codeium/windsurf/bin
  /Applications/Postgres.app/Contents/Versions/latest/bin
  /Applications/flutter/bin
  /bin
  $path
)

# Ruby via Homebrew (+ gem bin dir). Cacheado em ~/.cache/zsh/gem_bin — invalidar
# manualmente (rm) ao trocar versão do ruby. Custo sem cache: ~490ms (gem env gemdir).
if [ -n "$HOMEBREW_PREFIX" ] && [ -d "$HOMEBREW_PREFIX/opt/ruby/bin" ]; then
  path=("$HOMEBREW_PREFIX/opt/ruby/bin" $path)
  _gem_bin_cache="$HOME/.cache/zsh/gem_bin"
  if [ ! -f "$_gem_bin_cache" ]; then
    mkdir -p "${_gem_bin_cache:h}"
    gem environment gemdir 2>/dev/null > "$_gem_bin_cache"
  fi
  GEM_DIR="$(<"$_gem_bin_cache")"
  [ -n "$GEM_DIR" ] && [ -d "$GEM_DIR/bin" ] && path=("$GEM_DIR/bin" $path)
  unset _gem_bin_cache
fi
{{ else -}}
path=(
  $HOME/.local/bin
  $HOME/bin
  $HOME/.ghcup/bin
  $HOME/.emacs.d/bin
  /usr/local/bin
  /usr/local/sbin
  /usr/bin
  /bin
  $path
)
{{ end -}}

# ── Locale ────────────────────────────────────────────────────────────────────
export LC_NUMERIC="en_US.UTF-8"   # LANG/LC_ALL definidos em .zshenv
[[ -z "$TMUX" ]] && export TERM="xterm-256color"
{{ if eq .chezmoi.os "darwin" -}}
export ITERM_ENABLE_SHELL_INTEGRATION_WITH_TMUX=YES
unset OVERRIDE_XCODE
{{ end -}}

# ── Editor ────────────────────────────────────────────────────────────────────
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR="vim"
elif command -v lvim >/dev/null 2>&1; then
  export EDITOR="lvim"
else
  export EDITOR="nvim"
fi
export VISUAL="$EDITOR"

# ── Histórico ─────────────────────────────────────────────────────────────────
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_VERIFY SHARE_HISTORY EXTENDED_HISTORY

# ── Opções Zsh ────────────────────────────────────────────────────────────────
setopt AUTO_CD NO_BEEP GLOB_DOTS

# ── Oh-My-Zsh ─────────────────────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
export ZSH_CUSTOM="$HOME/.oh-my-zsh/custom"
ZSH_THEME="powerlevel10k/powerlevel10k"
DISABLE_AUTO_UPDATE="true"
DISABLE_UPDATE_PROMPT="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"   # git status rápido em repos grandes (Pinterest)
ENABLE_CORRECTION="true"
ZSH_COMPDUMP="${HOME}/.zcompdump-${ZSH_VERSION}"
# Skip OMZ compaudit (~40ms) — assumimos permissões corretas
ZSH_DISABLE_COMPFIX="true"
skip_global_compinit=1

# FPATH antes de carregar OMZ
{{ if eq .chezmoi.os "darwin" -}}
[ -n "$HOMEBREW_PREFIX" ] && FPATH="$HOMEBREW_PREFIX/share/zsh/site-functions:${FPATH}"
{{ else -}}
FPATH="/usr/share/zsh/site-functions:${FPATH}"
{{ end -}}

plugins=(
  git
  z
  history-substring-search
{{ if eq .chezmoi.os "darwin" -}}
  sudo
  colored-man-pages
  extract
{{ else -}}
  ruby
  rails
  sudo
  colored-man-pages
  extract
  archlinux
{{ end -}}
)

# compinit rápido: revalida o dump só 1x/dia (economiza ~40ms)
autoload -Uz compinit
if [[ -n "$ZSH_COMPDUMP"(#qN.mh-24) ]]; then
  compinit -C -d "$ZSH_COMPDUMP"
else
  compinit -d "$ZSH_COMPDUMP"
fi

source "$ZSH/oh-my-zsh.sh"

# ── Completions ───────────────────────────────────────────────────────────────
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' rehash true
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$HOME/.zsh_cache"

# ── Keybindings (modo emacs) ─────────────────────────────────────────────────
bindkey -e
bindkey '^[[A'  history-substring-search-up
bindkey '^[[B'  history-substring-search-down
bindkey '^P'    history-beginning-search-backward
bindkey '^N'    history-beginning-search-forward
bindkey '^R'    history-incremental-search-backward
bindkey '^[[H'  beginning-of-line
bindkey '^[[F'  end-of-line
bindkey '^[[3~' delete-char

# ── Aliases — navegação ───────────────────────────────────────────────────────
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

if command -v eza &>/dev/null; then
  alias ls='eza --icons'
  alias ll='eza -lh --icons --git'
  alias la='eza -lha --icons --git'
  alias lt='eza --tree --icons --level=2'
else
  alias ll='ls -lh --color=auto'
  alias la='ls -lha --color=auto'
  alias l='ls -l --color=auto'
fi

alias grep='grep --color=auto'
alias .='source'
alias reload='source'
alias zshs='source ~/.zshrc && clear'

# ── Aliases — sistema ─────────────────────────────────────────────────────────
{{ if eq .chezmoi.os "linux" -}}
alias updateAll='sudo pacman -Syyu && yay -Syyu && sudo flatpak update && echo "✅ Tudo atualizado!"'
alias clean='sudo pacman -Rns --noconfirm $(pacman -Qtdq) 2>/dev/null || echo "Nenhum órfão encontrado"'
alias orphan='pacman -Qtdq'
alias restartAudio='systemctl --user restart pipewire pipewire-pulse wireplumber'
alias designerfix='export XAUTHORITY=$(ls /run/user/1000/.mutter-Xwaylandauth* 2>/dev/null | head -1); QT_QPA_PLATFORM=xcb designer'
{{ else if eq .chezmoi.os "darwin" -}}
alias updateAll='brew upgrade && brew upgrade --cask --greedy && brew cleanup && omz update'
alias vim=nvim
[ -n "$HOMEBREW_PREFIX" ] && alias ctags="$HOMEBREW_PREFIX/bin/ctags"
alias shopt='/usr/bin/shopt'
alias sshLinux='ssh pietro@pietro-linux'

# cleanAllCache — limpa caches de user apps (NÃO ~/Library/Developer/Xcode/DerivedData → usa `mxc`).
cleanAllCache() {
    sudo rm -rf \
        "$HOME/Library/Caches" \
        "$HOME/Library/Logs" \
        /private/var/log/asl \
        "$HOME/Library/Containers/com.apple.mail/Data/Library/Mail Downloads" \
        /private/var/db/diagnostics \
        "$HOME/Library/Containers/com.apple.iMovieApp/Data/Library/Caches" \
        "$HOME/Library/Containers/com.apple.Safari/Data/Library/Caches" \
        /Library/Logs \
        "$HOME/Library/Containers/com.apple.iBooksX/Data/Library/Caches" \
        "$HOME/Library/Application Support/Code/Cache" \
        "$HOME/Library/Containers/com.tinyspeck.slackmacgap/Data/Library/Application Support/Slack/Cache" \
        "$HOME/Library/Application Support/discord/Cache" \
        "$HOME/Library/Containers/com.apple.mail/Data/Library/Caches" \
        "$HOME/Library/Containers/com.apple.QuickTimePlayerX/Data/Library/Caches/com.apple.avkit.thumbnailCache" 2>/dev/null
    sudo dscacheutil -flushcache
    sudo killall -HUP mDNSResponder
}
{{ end -}}

# ── Aliases — docker ─────────────────────────────────────────────────────────
alias dps='docker ps --format "table {{ "{{" }}.Names{{ "}}" }}\t{{ "{{" }}.Status{{ "}}" }}\t{{ "{{" }}.Ports{{ "}}" }}"'
alias dlog='docker logs -f'
alias dex='docker exec -it'
alias dprune='docker system prune -af --volumes'
alias dimg='docker images --format "table {{ "{{" }}.Repository{{ "}}" }}\t{{ "{{" }}.Tag{{ "}}" }}\t{{ "{{" }}.Size{{ "}}" }}"'

# ── Aliases — rails ──────────────────────────────────────────────────────────
alias r='./bin/rails'
alias rc='./bin/rails console'
alias rs='./bin/rails server'
alias rr='./bin/rails routes'

# ── Aliases — git ─────────────────────────────────────────────────────────────
alias gco='git checkout'
alias gsw='git switch'
alias gpff='git push -f --no-verify'
alias gmb="git for-each-ref --sort=-committerdate refs/heads/ --format='%(refname:short) - %(committerdate:relative) - %(objectname:short) - %(subject)'"

# ── zsh-defer (carrega plugins após o prompt aparecer) ───────────────────────
if [ -f ~/.zsh-defer/zsh-defer.plugin.zsh ]; then
  source ~/.zsh-defer/zsh-defer.plugin.zsh
else
  # Fallback: sem zsh-defer, carrega sincronamente.
  zsh-defer() { "$@"; }
fi

# ── Plugins externos (deferidos) ─────────────────────────────────────────────
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#666666"
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20
{{ if eq .chezmoi.os "darwin" -}}
[ -n "$HOMEBREW_PREFIX" ] && [ -f "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ] &&
  zsh-defer source "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
# syntax-highlighting tem que ser o ÚLTIMO source deferido
[ -n "$HOMEBREW_PREFIX" ] && [ -f "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ] &&
  zsh-defer source "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
{{ else -}}
[[ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]] &&
  zsh-defer source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
[[ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] &&
  zsh-defer source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{ end -}}

# ── FZF ───────────────────────────────────────────────────────────────────────
{{ if eq .chezmoi.os "linux" -}}
[[ -f /usr/share/fzf/key-bindings.zsh ]] && zsh-defer source /usr/share/fzf/key-bindings.zsh
[[ -f /usr/share/fzf/completion.zsh ]]   && zsh-defer source /usr/share/fzf/completion.zsh
{{ else -}}
[ -f ~/.fzf.zsh ] && zsh-defer source ~/.fzf.zsh
{{ end -}}
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --bind ctrl-/:toggle-preview'
if command -v bat &>/dev/null; then
  export FZF_CTRL_T_OPTS="--preview 'bat --color=always --line-range :200 {}'"
fi

# ── Mise (version manager) — lazy ─────────────────────────────────────────────
export ASDF_DATA_DIR="$HOME/.asdf"
if [ -d "$HOME/.local/share/mise/shims" ]; then
  export PATH="$HOME/.local/share/mise/shims:$PATH"
fi
mise() {
  unfunction mise 2>/dev/null
  eval "$(command mise activate zsh)"
  mise "$@"
}

# ── Rbenv — lazy ──────────────────────────────────────────────────────────────
if command -v rbenv >/dev/null 2>&1; then
  rbenv() {
    unfunction rbenv
    eval "$(command rbenv init - zsh)"
    rbenv "$@"
  }
fi

# ── NVM — lazy ────────────────────────────────────────────────────────────────
export NVM_DIR="$HOME/.nvm"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  _lazy_load_nvm() {
    unfunction nvm node npm npx 2>/dev/null
    \. "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
  }
  nvm()  { _lazy_load_nvm; nvm  "$@"; }
  node() { _lazy_load_nvm; node "$@"; }
  npm()  { _lazy_load_nvm; npm  "$@"; }
  npx()  { _lazy_load_nvm; npx  "$@"; }
fi

# ── Thefuck (lazy: só carrega quando chamado) ─────────────────────────────────
fuck() {
  unset -f fuck
  eval "$(thefuck --alias 2>/dev/null)"
  fuck "$@"
}

{{ if eq .chezmoi.os "darwin" -}}
# ── macOS: SSH Keychain (async em background, não bloqueia prompt) ────────────
(ssh-add --apple-use-keychain ~/.ssh/id_ed25519 &) > /dev/null 2>&1

# ── macOS: OpenSSL para gems ──────────────────────────────────────────────────
if [ -n "$HOMEBREW_PREFIX" ] && [ -d "$HOMEBREW_PREFIX/opt/openssl@3" ]; then
  export LDFLAGS="-L$HOMEBREW_PREFIX/opt/openssl@3/lib"
  export CPPFLAGS="-I$HOMEBREW_PREFIX/opt/openssl@3/include"
  export PKG_CONFIG_PATH="$HOMEBREW_PREFIX/opt/openssl@3/lib/pkgconfig"
fi

# ── macOS: Homebrew performance (M4 Max) ─────────────────────────────────────
[ -f ~/.homebrew_config ] && source ~/.homebrew_config

# ── macOS: M4 Max build parallelism ──────────────────────────────────────────
export MAKEFLAGS="-j16"
export CARGO_BUILD_JOBS=16
export SWIFT_EXEC_THREADS=16
export UV_THREADPOOL_SIZE=16
export TUIST_STATS_OPT_OUT=1
export CHOKIDAR_USEPOLLING=false
export WATCHMAN_MAX_DEPTH=10

# ── macOS: Pinterest iOS workflow (mx/mxa/mxw/mxc/mxd/mxs/fastbuild/kx/kxd) ──
# Bloco extenso — separado em ~/.zshrc.d/pinterest.zsh (gerido pelo chezmoi, profile=work).
{{ if eq .profile "work" -}}
[ -f "$HOME/.zshrc.d/pinterest.zsh" ] && source "$HOME/.zshrc.d/pinterest.zsh"
{{- end }}
{{ end -}}

# ── Powerlevel10k theme ───────────────────────────────────────────────────────
# darwin: OMZ carrega via ZSH_THEME="powerlevel10k/powerlevel10k" (custom/themes). Sem source extra.
{{ if eq .chezmoi.os "linux" -}}
# Linux: tema vem do pacote zsh-theme-powerlevel10k (fora do OMZ).
[ -f /usr/share/zsh-theme-powerlevel10k/powerlevel10k.zsh-theme ] &&
  source /usr/share/zsh-theme-powerlevel10k/powerlevel10k.zsh-theme

# ── Linux: SSH agent persistente (keychain) ──────────────────────────────────
# Requer: pacman -S keychain. Pede passphrase 1x por boot e reusa em todo shell.
if command -v keychain >/dev/null 2>&1; then
  eval "$(keychain --eval --quiet --agents ssh id_ed25519 2>/dev/null)"
elif [ -z "$SSH_AUTH_SOCK" ] && command -v ssh-agent >/dev/null 2>&1; then
  # Fallback: agente por sessão (pede passphrase 1x por shell)
  eval "$(ssh-agent -s)" >/dev/null
  ssh-add ~/.ssh/id_ed25519 2>/dev/null
fi
{{ end -}}
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh
