[general]
live_config_reload = true
import = ["~/.config/alacritty/catppuccin-mocha.toml"]

[font]
{{ if eq .chezmoi.os "darwin" -}}
size = 12.0
{{ else -}}
size = 13.0
{{ end -}}
builtin_box_drawing = true

[font.offset]
x = 0
y = 1

[font.normal]
family = "JetBrainsMono Nerd Font"
style  = "Regular"

[font.bold]
family = "JetBrainsMono Nerd Font"
style  = "Bold"

[font.italic]
family = "JetBrainsMono Nerd Font"
style  = "Italic"

[font.bold_italic]
family = "JetBrainsMono Nerd Font"
style  = "Bold Italic"

[window]
{{ if eq .chezmoi.os "darwin" -}}
decorations     = "Full"
startup_mode    = "Windowed"
dimensions      = { columns = 180, lines = 50 }
option_as_alt   = "Both"
opacity         = 0.95
blur            = true
{{ else -}}
decorations = "full"
opacity     = 1.0
{{ end -}}
dynamic_title   = true
dynamic_padding = true
padding         = { x = 8, y = 8 }

[scrolling]
history = 10000

[cursor]
style = { shape = "Block", blinking = "On" }

[terminal.shell]
{{ if eq .chezmoi.os "darwin" -}}
program = "/usr/local/bin/tmux"
{{ else -}}
program = "/usr/bin/tmux"
{{ end -}}
args    = ["new-session", "-A", "-s", "main"]

[[keyboard.bindings]]
chars = "\u001B\u007F"
key   = "Back"
mods  = "Alt"

[[keyboard.bindings]]
action = "ScrollPageUp"
key    = "PageUp"
mode   = "~Alt"
mods   = "Shift"

[[keyboard.bindings]]
action = "ScrollPageDown"
key    = "PageDown"
mode   = "~Alt"
mods   = "Shift"

[[keyboard.bindings]]
action = "ScrollToTop"
key    = "Home"
mode   = "~Alt"
mods   = "Shift"

[[keyboard.bindings]]
action = "ScrollToBottom"
key    = "End"
mode   = "~Alt"
mods   = "Shift"
