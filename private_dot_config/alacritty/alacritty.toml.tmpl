[general]
import = ["~/.config/alacritty/catppuccin-mocha.toml"]

[font]
{{ if eq .chezmoi.os "darwin" -}}
size = 14.0

[font.normal]
family = "MesloLGS NF"
style  = "Regular"

[font.bold]
family = "MesloLGS NF"
style  = "Bold"

[font.italic]
family = "MesloLGS NF"
style  = "Italic"
{{ else -}}
size = 13.0

[font.normal]
family = "JetBrainsMono Nerd Font"
style  = "Regular"

[font.bold]
family = "JetBrainsMono Nerd Font"
style  = "Bold"

[font.italic]
family = "JetBrainsMono Nerd Font"
style  = "Italic"
{{ end -}}

[window]
{{ if eq .chezmoi.os "darwin" -}}
decorations   = "None"
startup_mode  = "Fullscreen"
option_as_alt = "Both"
{{ else -}}
decorations = "full"
opacity     = 1.0
{{ end -}}
dynamic_title = true
padding = { x = 8, y = 8 }

[scrolling]
history = 10000

[cursor]
style = { shape = "Block", blinking = "On" }

[terminal.shell]
program = "/bin/zsh"
args    = ["-l", "-c", "tmux new -A"]

[[keyboard.bindings]]
chars = "\u001B\u007F"
key   = "Back"
mods  = "Alt"

[[keyboard.bindings]]
action = "ScrollPageUp"
key    = "PageUp"
mode   = "~Alt"
mods   = "Shift"

[[keyboard.bindings]]
action = "ScrollPageDown"
key    = "PageDown"
mode   = "~Alt"
mods   = "Shift"

[[keyboard.bindings]]
action = "ScrollToTop"
key    = "Home"
mode   = "~Alt"
mods   = "Shift"

[[keyboard.bindings]]
action = "ScrollToBottom"
key    = "End"
mode   = "~Alt"
mods   = "Shift"
